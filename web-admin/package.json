{
  "name": "web-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:serve": "node server.cjs",
    "dev:all": "npm-run-all -p dev dev:serve",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "serve": "node server.cjs",
    "package:win": "node scripts/package-win.cjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:4173"
    ,
    "test:cleanup": "node scripts/cleanup-e2e.cjs",
    "test:e2e:all": "playwright test && node scripts/cleanup-e2e.cjs"
  },
  "dependencies": {
    "tcb-admin-node": "^1.23.0",
    "@cloudbase/js-sdk": "^2.15.1",
    "finalhandler": "^1.2.0",
    "mime": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "serve-static": "^1.15.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@playwright/test": "^1.47.2",
    "npm-run-all": "^4.1.5",
    "pkg": "^5.8.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
